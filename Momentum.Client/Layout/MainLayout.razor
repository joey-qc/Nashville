@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject ClientAuthService AuthService
@implements IDisposable

<AuthorizeView>

    <Authorized Context="authContext">
        <div class="app-shell @(_collapsed ? "collapsed" : "") @(_mobileOpen ? "mobile-open" : "")">

            <!-- ═══ Sidebar ═══ -->
            <aside class="sidebar">

                <!-- Brand -->
                <div class="sidebar-brand">
                    <svg class="brand-logo" viewBox="0 0 32 28" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M16 2L30 26H2L16 2Z" fill="var(--primary)" opacity="0.9"/>
                        <path d="M9 26L16 14L23 26Z" fill="var(--primary-dim)"/>
                    </svg>
                    <div class="brand-text">
                        <span class="brand-name">Momentum</span>
                        <span class="brand-sub">Daily wellness</span>
                    </div>
                </div>

                <!-- Nav -->
                <nav class="sidebar-nav">

                    <a href="/" class="nav-item @(GetPath() == "/" ? "active" : "")">
                        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" fill="currentColor"/>
                        </svg>
                        <span class="nav-label">Home</span>
                    </a>

                    <a href="/log" class="nav-item @(IsAddEntryActive ? "active" : "")">
                        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z" fill="currentColor"/>
                        </svg>
                        <span class="nav-label">Add Entry</span>
                    </a>

                    <a href="/log/detail" class="nav-item @(GetPath().StartsWith("/log/detail") ? "active" : "")">
                        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z" fill="currentColor"/>
                        </svg>
                        <span class="nav-label">View Log</span>
                    </a>

                    <!-- Reports — desktop icon-rail shows a direct link; expanded nav (or mobile open drawer) shows collapsible group -->
                    @if (_collapsed && !_mobileOpen)
                    {
                        <!-- Desktop icon-rail only: icon with no label, navigates directly to /reports -->
                        <a href="/reports" class="nav-item @(IsReportsActive ? "active" : "")">
                            <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z" fill="currentColor"/>
                            </svg>
                        </a>
                    }
                    else
                    {
                        <!-- Full nav (desktop expanded or mobile open drawer): label + chevron + children -->
                        <button type="button"
                                class="nav-item nav-group-toggle @(IsReportsActive ? "active" : "")"
                                @onclick="ToggleReports"
                                aria-expanded="@(_reportsExpanded ? "true" : "false")"
                                aria-controls="reports-submenu">
                            <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z" fill="currentColor"/>
                            </svg>
                            <span class="nav-label">Reports</span>
                            <svg class="nav-chevron @(_reportsExpanded ? "expanded" : "")" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                                <path d="M7 10l5 5 5-5z" fill="currentColor"/>
                            </svg>
                        </button>

                        <div id="reports-submenu">
                            @if (_reportsExpanded)
                            {
                                <a href="/reports" class="nav-item nav-child @(GetPath() == "/reports" ? "active" : "")">
                                    <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z" fill="currentColor"/>
                                    </svg>
                                    <span class="nav-label">Trends</span>
                                </a>
                                <a href="/reports/balance" class="nav-item nav-child @(GetPath().StartsWith("/reports/balance") ? "active" : "")">
                                    <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z" fill="currentColor"/>
                                    </svg>
                                    <span class="nav-label">Balance</span>
                                </a>
                            }
                        </div>
                    }

                    <a href="/activities" class="nav-item @(GetPath().StartsWith("/activities") ? "active" : "")">
                        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M20.57 14.86L22 13.43 20.57 12 17 15.57 8.43 7 12 3.43 10.57 2 9.14 3.43 7.71 2 5.57 4.14 4.14 2.71 2.71 4.14l1.43 1.43L2 7.71l1.43 1.43L2 10.57 3.43 12 7 8.43 15.57 17 12 20.57 13.43 22l1.43-1.43L16.29 22l2.14-2.14 1.43 1.43 1.43-1.43-1.43-1.43L22 16.29z" fill="currentColor"/>
                        </svg>
                        <span class="nav-label">Manage Activities</span>
                    </a>

                    <a href="/settings" class="nav-item @(GetPath().StartsWith("/settings") ? "active" : "")">
                        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" fill="currentColor"/>
                        </svg>
                        <span class="nav-label">Settings</span>
                    </a>

                </nav>

                <!-- Footer: user name + logout -->
                <div class="sidebar-footer">
                    <div class="user-display">
                        <svg viewBox="0 0 24 24" width="18" height="18" style="flex-shrink:0;color:var(--text-muted)" aria-hidden="true">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor"/>
                        </svg>
                        <span class="user-name">@(authContext.User.FindFirst("displayName")?.Value ?? authContext.User.Identity?.Name ?? "")</span>
                    </div>
                    <button type="button" class="logout-btn" @onclick="Logout" title="Sign out">
                        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                            <path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" fill="currentColor"/>
                        </svg>
                        <span class="logout-label">Sign out</span>
                    </button>
                </div>

            </aside>

            <!-- ═══ Mobile overlay — tap to close sidebar ═══ -->
            @if (_mobileOpen)
            {
                <div class="mobile-overlay" @onclick="CloseMobileSidebar" aria-hidden="true"></div>
            }

            <!-- ═══ Main area ═══ -->
            <div class="main-wrapper">

                <header class="topbar">
                    <button type="button" class="hamburger" @onclick="ToggleSidebar" title="Toggle sidebar">
                        <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
                            <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" fill="currentColor"/>
                        </svg>
                    </button>
                    <span class="topbar-title">@PageTitle</span>
                    <a href="/log" class="topbar-cta">+ Add Entry</a>
                </header>

                <main class="page-content">
                    @Body
                </main>

            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <div class="auth-shell">@Body</div>
    </NotAuthorized>

    <Authorizing>
        <div class="auth-shell"></div>
    </Authorizing>

</AuthorizeView>

@code {
    private bool _collapsed;
    private bool _mobileOpen;
    private bool _reportsExpanded = true;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        if (GetPath().StartsWith("/reports"))
            _reportsExpanded = true;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _mobileOpen = false;   // always close mobile drawer on navigation
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
        => Navigation.LocationChanged -= OnLocationChanged;

    // Toggles both booleans — CSS media queries decide which one has visible effect
    // at the current viewport: _collapsed drives desktop icon-collapse,
    // _mobileOpen drives the mobile overlay drawer.
    private void ToggleSidebar()
    {
        _collapsed = !_collapsed;
        _mobileOpen = !_mobileOpen;
    }

    // Called by the mobile overlay tap — only closes the mobile drawer.
    private void CloseMobileSidebar() => _mobileOpen = false;

    private void ToggleReports() => _reportsExpanded = !_reportsExpanded;

    private string GetPath()
    {
        var baseUri = Navigation.BaseUri;
        var uri = Navigation.Uri;
        var relative = uri.StartsWith(baseUri) ? uri[baseUri.Length..] : uri;
        var path = relative.Split('?')[0].Split('#')[0].TrimStart('/');
        return path.Length == 0 ? "/" : "/" + path;
    }

    private bool IsAddEntryActive
    {
        get { var p = GetPath(); return p.StartsWith("/log") && !p.StartsWith("/log/detail"); }
    }

    private bool IsReportsActive => GetPath().StartsWith("/reports");

    private string PageTitle => GetPath() switch
    {
        "/" => "Home",
        var p when p.StartsWith("/log/detail") => "View Log",
        var p when p.StartsWith("/log") => "Add Entry",
        var p when p.StartsWith("/reports/balance") => "Balance",
        var p when p.StartsWith("/reports") => "Trends",
        var p when p.StartsWith("/activities") => "Manage Activities",
        var p when p.StartsWith("/settings") => "Settings",
        _ => "Momentum"
    };

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
