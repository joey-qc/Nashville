@page "/"
@attribute [Authorize]
@inject ScoreService ScoreService
@inject ReportsService ReportsService
@inject ActivityLogService LogService
@inject CategoryService CategoryService
@inject NavigationManager Navigation

<PageTitle>Home — Momentum</PageTitle>

@if (_loading)
{
    <div class="home-loading">
        <p class="loading-text">Loading your data…</p>
    </div>
}
else
{
<div class="home">

    <!-- ══ PAGE HEADER ══ -->
    <header class="home-header">
        <p class="home-date">@DateLine</p>
        <h1 class="home-welcome">Welcome back, @_displayName</h1>
        <p class="home-subtitle">Keep going — small wins compound.</p>
    </header>

    <!-- ══ HERO ROW: Today's Momentum + KPI stack ══ -->
    <div class="home-row hero-row">

        <!-- Today's Momentum card -->
        <div class="card momentum-card">
            <div class="card-head">
                <span class="card-label">TODAY'S MOMENTUM</span>
            </div>
            <div class="momentum-body">

                <!-- Score ring -->
                <div class="ring-wrap">
                    <svg class="progress-ring" viewBox="0 0 140 140" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="ringGrad" x1="0" y1="0" x2="1" y2="1">
                                <stop offset="0%" stop-color="#8DF35F"/>
                                <stop offset="100%" stop-color="#4FB02C"/>
                            </linearGradient>
                        </defs>
                        <!-- Track (background circle) -->
                        <circle class="ring-track" cx="70" cy="70" r="52"/>
                        <!-- Ring fill: green gradient for positive, muted red for negative/zero -->
                        <circle class="ring-full" cx="70" cy="70" r="52"
                                stroke="@(IsNegativeDay ? "var(--negative)" : "url(#ringGrad)")"
                                stroke-opacity="@(IsNegativeDay ? "0.4" : "1")"/>
                        <!-- Center: today's total -->
                        <text x="70" y="64" class="ring-score-text @(IsNegativeDay ? "ring-score-neg" : "")" text-anchor="middle">@(_summary?.TodayTotal ?? 0)</text>
                        <text x="70" y="82" class="ring-score-label" text-anchor="middle">TODAY</text>
                    </svg>
                </div>

                <!-- Score + category breakdown -->
                <div class="momentum-stats">
                    <div class="cat-bars">
                        @foreach (var cat in PositiveCats)
                        {
                            <div class="cat-bar-row">
                                <span class="cat-bar-name">@cat.CategoryName</span>
                                <div class="cat-bar-track">
                                    <div class="cat-bar-fill"
                                         style="width:@(CatPct(cat.Total).ToString("F1"))%;background:@cat.ColorHex">
                                    </div>
                                </div>
                                <span class="cat-bar-pts">+@cat.Total</span>
                            </div>
                        }
                        @if (HasSetbacks)
                        {
                            <div class="cat-bar-row">
                                <span class="cat-bar-name">Setbacks</span>
                                <div class="cat-bar-track">
                                    <div class="cat-bar-fill setback-fill"
                                         style="width:@(CatPct(SetbacksTotal).ToString("F1"))%">
                                    </div>
                                </div>
                                <span class="cat-bar-pts neg">@SetbacksTotal</span>
                            </div>
                        }
                        @if (!_todayByCategory.Any())
                        {
                            <p class="no-data-hint">No activity logged today yet.</p>
                        }
                    </div>
                </div>

            </div>
        </div>

        <!-- KPI stack (right column) -->
        <div class="kpi-stack">

            <!-- This Week -->
            <div class="card kpi-card" @onclick='() => Navigation.NavigateTo("/log/detail?period=week")'>
                <div class="kpi-top">
                    <span class="card-label">THIS WEEK</span>
                    @if (LastWeekTotal > 0)
                    {
                        <span class="kpi-delta @(WeekDelta >= 0 ? "pos" : "neg")">
                            @(WeekDelta >= 0 ? "↑" : "↓") @Math.Abs(WeekDelta)%
                        </span>
                    }
                </div>
                <div class="kpi-value">@(_summary?.WeekTotal ?? 0) <span class="kpi-unit">pts</span></div>
                @if (WeekSparkPath.Length > 0)
                {
                    <svg class="sparkline" viewBox="0 0 80 28" preserveAspectRatio="none">
                        <path d="@WeekSparkPath" class="spark-line week-spark"/>
                    </svg>
                }
            </div>

            <!-- This Month -->
            <div class="card kpi-card" @onclick='() => Navigation.NavigateTo("/log/detail?period=month")'>
                <div class="kpi-top">
                    <span class="card-label">THIS MONTH</span>
                    @if (_last2Months.Count >= 2 && _last2Months[0].Total > 0)
                    {
                        <span class="kpi-delta @(MonthDelta >= 0 ? "pos" : "neg")">
                            @(MonthDelta >= 0 ? "↑" : "↓") @Math.Abs(MonthDelta)%
                        </span>
                    }
                </div>
                <div class="kpi-value">@(_summary?.MonthTotal ?? 0) <span class="kpi-unit">pts</span></div>
                @if (MonthSparkPath.Length > 0)
                {
                    <svg class="sparkline" viewBox="0 0 80 28" preserveAspectRatio="none">
                        <path d="@MonthSparkPath" class="spark-line month-spark"/>
                    </svg>
                }
            </div>

        </div>
    </div>

    <!-- ══ SPLIT ROW: Bar chart + Activity list ══ -->
    <div class="home-row split-row">

        <!-- Weekly bar chart -->
        <div class="card chart-card">
            <div class="card-head">
                <span class="card-title">This week vs. last week</span>
                <div class="chart-legend">
                    <span class="legend-swatch" style="background:var(--primary)"></span>
                    <span class="legend-label">This week</span>
                    <span class="legend-swatch" style="background:var(--text-muted)"></span>
                    <span class="legend-label">Last week</span>
                </div>
            </div>
            @if (_comparison?.Days is { Count: > 0 })
            {
                <svg class="bar-svg" viewBox="0 0 500 200" preserveAspectRatio="xMidYMid meet">
                    <!-- Y-axis gridlines + labels -->
                    <!-- Note: <text> is a reserved Razor tag, so SVG text nodes must use @((MarkupString)...) -->
                    @foreach (var (ty, tv) in YTicks())
                    {
                        var tyStr = ty.ToString("F0");
                        <line x1="@ChL" y1="@tyStr" x2="490" y2="@tyStr"
                              stroke="var(--border-soft)" stroke-width="1"/>
                        @((MarkupString)$"<text x=\"34\" y=\"{tyStr}\" dominant-baseline=\"central\" text-anchor=\"end\" style=\"font-size:9px;fill:var(--chart-label)\">{tv}</text>")
                    }
                    <!-- Bars + x-labels -->
                    @for (int idx = 0; idx < _comparison.Days.Count; idx++)
                    {
                        var day = _comparison.Days[idx];
                        var cx  = BarX(idx, true).ToString("F1");
                        var lx  = BarX(idx, false).ToString("F1");
                        var ch  = BarH(day.CurrentWeek).ToString("F1");
                        var lh  = BarH(day.LastWeek).ToString("F1");
                        var cy  = BarY(day.CurrentWeek).ToString("F1");
                        var ly  = BarY(day.LastWeek).ToString("F1");
                        var lbx = LabelX(idx).ToString("F1");
                        <rect x="@cx" y="@cy" width="@BarW" height="@ch" fill="var(--primary)" rx="3"/>
                        <rect x="@lx" y="@ly" width="@BarW" height="@lh" fill="var(--text-muted)" rx="3"/>
                        @((MarkupString)$"<text x=\"{lbx}\" y=\"193\" text-anchor=\"middle\" style=\"font-size:9px;fill:var(--chart-label)\">{day.DayLabel[0]}</text>")
                    }
                </svg>
            }
            else
            {
                <p class="no-data-hint">No comparison data available.</p>
            }
        </div>

        <!-- Today's activity list -->
        <div class="card activity-card">
            <div class="card-head">
                <div>
                    <span class="card-title">Today's activity</span>
                    <p class="card-sub">@_todayLogs.Count @(_todayLogs.Count == 1 ? "entry" : "entries") · @(_summary?.TodayTotal ?? 0) pts</p>
                </div>
                <a href="/log/detail?period=today" class="view-all-link">View all →</a>
            </div>
            <div class="activity-list">
                @if (_todayLogs.Any())
                {
                    @foreach (var log in _todayLogs.OrderByDescending(l => l.LoggedAt).Take(5))
                    {
                        var bc = log.Categories.Count > 0 ? log.Categories[0].ColorHex : "#4A6080";
                        <div class="activity-row">
                            <div class="activity-badge" style="background:@(bc)1A;border:1px solid @(bc)44">
                                <svg viewBox="0 0 12 12" width="10" height="10">
                                    <circle cx="6" cy="6" r="4" fill="@bc"/>
                                </svg>
                            </div>
                            <div class="activity-info">
                                <span class="activity-name" title="@log.ActivityName">@log.ActivityName</span>
                                <span class="activity-time">@log.LoggedAt.ToLocalTime().ToString("h:mm tt")</span>
                            </div>
                            <div class="activity-cats">
                                @foreach (var cat in log.Categories.Take(2))
                                {
                                    <span class="cat-tag" style="background:@(cat.ColorHex)1A;color:@cat.ColorHex">@cat.Name</span>
                                }
                            </div>
                            <span class="pts-pill @(log.PointsRecorded >= 0 ? "pos" : "neg")">
                                @(log.PointsRecorded > 0 ? "+" : "")@log.PointsRecorded
                            </span>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-activity">
                        <p class="no-data-hint">No entries today yet.</p>
                        <a href="/log" class="log-first-link">+ Log your first activity</a>
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- ══ WEEKLY CATEGORY BREAKDOWN ══ -->
    <div class="card wkb-card">
        <div class="card-head">
            <span class="card-title">This week by dimension</span>
        </div>
        @if (_weekBalance.Count == 0)
        {
            <p class="no-data-hint">No activity logged this week.</p>
        }
        else
        {
            <!-- Stacked proportion bar -->
            <div class="wkb-stack">
                @foreach (var cat in _weekBalance)
                {
                    var segPct = GrandWeekTotal > 0
                        ? (cat.Total * 100.0 / GrandWeekTotal).ToString("F1", System.Globalization.CultureInfo.InvariantCulture)
                        : "0.0";
                    <div class="wkb-seg" style="width:@segPct%;background:@cat.ColorHex"
                         title="@cat.CategoryName: @cat.Total pts"></div>
                }
            </div>
            <!-- Category rows -->
            <div class="wkb-list">
                @foreach (var cat in _weekBalance)
                {
                    var pct     = GrandWeekTotal > 0 ? (int)Math.Round(cat.Total * 100.0 / GrandWeekTotal) : 0;
                    var fillPct = GrandWeekTotal > 0 ? Math.Min(100.0, cat.Total * 100.0 / GrandWeekTotal) : 0.0;
                    var fillStr = fillPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                    <div class="wkb-row">
                        <span class="wkb-dot" style="background:@cat.ColorHex"></span>
                        <div class="wkb-info">
                            <span class="wkb-name">@cat.CategoryName</span>
                            <span class="wkb-sub">@cat.Total pts</span>
                        </div>
                        <span class="wkb-pct">@pct%</span>
                        <div class="wkb-track">
                            <div class="wkb-fill" style="width:@fillStr%;background:@cat.ColorHex"></div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    /* Bar chart SVG geometry */
    private const double ChL = 40;   // left x of chart area
    private const double ChT = 15;   // top y
    private const double ChB = 170;  // bottom y of bars
    private const double ChH = 155;  // chart height (ChB - ChT)
    private const double ChW = 450;  // chart width  (490 - ChL)
    private const double BarW = 14;  // individual bar pixel width

    /* ── State ───────────────────────────────────────────────── */
    private ScoreSummaryDto?         _summary;
    private WeeklyComparisonDto?     _comparison;
    private List<CategoryTotalDto>   _todayByCategory = [];
    private List<ActivityLogDto>     _todayLogs       = [];
    private List<DailyScoreDto>      _last30Days      = [];
    private List<DailyScoreDto>      _last2Months     = [];
    private List<CategoryTotalDto>   _weekBalance     = [];
    private string _displayName = "there";
    private bool   _loading     = true;

    // Canonical display order: Physical(1) → Mental(2) → Spiritual(3) → Social(4) → Housekeeping(5)
    private static readonly int[] _canonicalCatOrder = [1, 2, 3, 4, 5];

    /* ── Computed: header ─────────────────────────────────────── */
    private string DateLine =>
        DateTime.Now.ToString("dddd").ToUpper() + " · " +
        DateTime.Now.ToString("MMMM d").ToUpper();

    /* ── Computed: category bars ──────────────────────────────── */
    private int    CatBarMax      => _todayByCategory.Count > 0 ? Math.Max(1, _todayByCategory.Max(c => Math.Abs(c.Total))) : 1;
    private double CatPct(int v)  => Math.Min(100, Math.Abs(v) * 100.0 / CatBarMax);
    private IEnumerable<CategoryTotalDto> PositiveCats => _todayByCategory.Where(c => c.Total > 0).OrderByDescending(c => c.Total);
    // Sum negative log points directly — do NOT sum per-category totals, which would
    // count a multi-category entry's points once per category (double/triple counting).
    private int    SetbacksTotal  => _todayLogs.Where(l => l.PointsRecorded < 0).Sum(l => l.PointsRecorded);
    private bool   HasSetbacks    => SetbacksTotal < 0;
    private bool   IsNegativeDay  => (_summary?.TodayTotal ?? 0) < 0;

    /* ── Computed: weekly category breakdown ─────────────────── */
    private int GrandWeekTotal => _weekBalance.Where(b => b.Total > 0).Sum(b => b.Total);

    /* ── Computed: week/month deltas ──────────────────────────── */
    private int LastWeekTotal => _comparison?.Days.Sum(d => d.LastWeek) ?? 0;

    private int WeekDelta
    {
        get
        {
            var last = LastWeekTotal;
            return last == 0 ? 0 : (int)Math.Round((_summary?.WeekTotal - last ?? 0) * 100.0 / last);
        }
    }

    private int MonthDelta
    {
        get
        {
            if (_last2Months.Count < 2) return 0;
            var last = _last2Months[0].Total;
            return last == 0 ? 0 : (int)Math.Round((_summary?.MonthTotal - last ?? 0) * 100.0 / last);
        }
    }

    /* ── Computed: sparklines ─────────────────────────────────── */
    private string WeekSparkPath  => MakeSpark(_comparison?.Days.Select(d => d.CurrentWeek).ToList() ?? []);
    private string MonthSparkPath => MakeSpark(_last30Days.Select(d => d.Total).ToList());

    private static string MakeSpark(IList<int> vals, double w = 80, double h = 28)
    {
        if (vals.Count < 2) return "";
        var max   = Math.Max(1, vals.Max());
        var min   = Math.Min(0, vals.Min());
        var range = Math.Max(1, max - min);
        var sb    = new System.Text.StringBuilder();
        for (int i = 0; i < vals.Count; i++)
        {
            var x = i * w / (vals.Count - 1);
            var y = h - (vals[i] - min) * h / range;
            sb.Append(i == 0 ? $"M {x:F1} {y:F1}" : $" L {x:F1} {y:F1}");
        }
        return sb.ToString();
    }

    /* ── Computed: bar chart geometry ─────────────────────────── */
    private double BarChartMax
    {
        get
        {
            var days = _comparison?.Days;
            if (days is null || days.Count == 0) return 10;
            var raw = days.Max(d => Math.Max(d.CurrentWeek, d.LastWeek));
            return Math.Max(5, Math.Ceiling(raw * 1.2 / 5) * 5);
        }
    }

    private double BarX(int i, bool isCurrent)
    {
        var gw        = ChW / 7;
        var gStart    = ChL + i * gw;
        var barsTotal = 2 * BarW + 4;
        var bStart    = gStart + (gw - barsTotal) / 2;
        return isCurrent ? bStart : bStart + BarW + 4;
    }
    private double BarH(int v) => Math.Max(0, v * ChH / BarChartMax);
    private double BarY(int v) => ChB - BarH(v);
    private double LabelX(int i) => ChL + i * (ChW / 7) + ChW / 14;

    private IEnumerable<(double y, int val)> YTicks()
    {
        for (int i = 0; i <= 4; i++)
            yield return (ChB - i * ChH / 4, (int)(i * BarChartMax / 4));
    }

    /* ── Data loading ─────────────────────────────────────────── */
    protected override async Task OnInitializedAsync()
    {
        // ── Auth guard ────────────────────────────────────────────
        // Must check BEFORE any API call. During a logout race the auth state
        // propagates asynchronously; without this guard Home fires API calls
        // with a cleared token and receives 401 errors.
        if (AuthState is null)
        {
            _loading = false;
            return;
        }
        var state = await AuthState;
        if (!(state.User.Identity?.IsAuthenticated ?? false))
        {
            _loading = false;
            return; // AuthorizeView / router will navigate to /login
        }
        _displayName = state.User.FindFirst("displayName")?.Value
                    ?? state.User.Identity?.Name
                    ?? "there";

        var todayUtc = DateTime.UtcNow.Date;

        var tSummary     = ScoreService.GetSummaryAsync();
        var tCompare     = ScoreService.GetWeeklyComparisonAsync();
        var tLogs        = LogService.GetByDateRangeAsync(todayUtc, todayUtc.AddDays(1));
        var tDaily       = ReportsService.GetDailyAsync(31);
        var tMonthly     = ReportsService.GetMonthlyAsync(2);
        var tWeekBalance = ReportsService.GetBalanceAsync("week");

        await Task.WhenAll(tSummary, tCompare, tLogs, tDaily, tMonthly, tWeekBalance);

        _summary     = tSummary.Result;
        _comparison  = tCompare.Result;
        _todayLogs   = tLogs.Result;
        _last30Days  = tDaily.Result.TakeLast(30).ToList();
        _last2Months = tMonthly.Result;

        // Weekly category breakdown — canonical order, positive categories only
        _weekBalance = tWeekBalance.Result
            .Where(b => b.Total > 0)
            .OrderBy(b => { var i = Array.IndexOf(_canonicalCatOrder, b.CategoryId); return i < 0 ? 999 : i; })
            .ToList();

        // Build today's category breakdown directly from today's logs.
        // Note: DailyScoreDto.ByCategory is never populated by the reports API (only Date+Total
        // are filled), so we derive category totals from the logs we already fetched above.
        _todayByCategory = _todayLogs
            .SelectMany(log => log.Categories.Select(cat => new
            {
                cat.Id,
                cat.Name,
                cat.ColorHex,
                Points = log.PointsRecorded
            }))
            .GroupBy(x => new { x.Id, x.Name, x.ColorHex })
            .Select(g => new CategoryTotalDto
            {
                CategoryId   = g.Key.Id,
                CategoryName = g.Key.Name,
                ColorHex     = g.Key.ColorHex,
                Total        = g.Sum(x => x.Points)
            })
            .Where(c => c.Total != 0)
            .ToList();

        _loading = false;
    }
}
