@page "/register"
@inject ClientAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Create account — Momentum</PageTitle>

<div class="auth-page">

    <!-- ═══ Brand ═══ -->
<div class="auth-brand">
    <img class="auth-brand-logo"
         src="brand/momentum-logo-dark.svg"
         alt="Momentum" />
</div>

    <!-- ═══ Auth card ═══ -->
    <div class="auth-card">

        <div class="auth-card-header">
            <span class="auth-eyebrow">START A STREAK</span>
            <h1 class="auth-title">Create account</h1>
            <p class="auth-subtitle">Build your momentum from day one.</p>
        </div>

        <!-- Error banner -->
        @if (errors.Any())
        {
            <div class="auth-alert auth-alert-error">
                @string.Join(" ", errors)
            </div>
        }

        <form @onsubmit="HandleRegister" @onsubmit:preventDefault>

            <!-- Display Name -->
            <div class="auth-field">
                <label class="auth-field-label" for="reg-name">DISPLAY NAME</label>
                <input id="reg-name"
                       type="text"
                       class="auth-field-input"
                       placeholder="Your name"
                       autocomplete="name"
                       maxlength="100"
                       value="@model.DisplayName"
                       @oninput="@(e => model.DisplayName = e.Value?.ToString() ?? "")" />
            </div>

            <!-- Email -->
            <div class="auth-field">
                <label class="auth-field-label" for="reg-email">EMAIL</label>
                <input id="reg-email"
                       type="email"
                       class="auth-field-input"
                       placeholder="you@example.com"
                       autocomplete="email"
                       value="@model.Email"
                       @oninput="@(e => model.Email = e.Value?.ToString() ?? "")" />
            </div>

            <!-- Password -->
            <div class="auth-field">
                <label class="auth-field-label" for="reg-password">PASSWORD</label>
                <div class="auth-field-inner">
                    <input id="reg-password"
                           type="@(_showPassword ? "text" : "password")"
                           class="auth-field-input"
                           placeholder="••••••••"
                           autocomplete="new-password"
                           value="@model.Password"
                           @oninput="@(e => model.Password = e.Value?.ToString() ?? "")" />
                    <button type="button" class="pw-toggle" @onclick="TogglePassword"
                            aria-label="@(_showPassword ? "Hide password" : "Show password")">
                        @if (_showPassword)
                        {
                            <!-- Eye-off icon -->
                            <svg viewBox="0 0 24 24" width="17" height="17" fill="none"
                                 stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                <line x1="1" y1="1" x2="23" y2="23"/>
                            </svg>
                        }
                        else
                        {
                            <!-- Eye icon -->
                            <svg viewBox="0 0 24 24" width="17" height="17" fill="none"
                                 stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        }
                    </button>
                </div>
            </div>

            <!-- Confirm Password -->
            <div class="auth-field">
                <label class="auth-field-label" for="reg-confirm-password">CONFIRM PASSWORD</label>
                <div class="auth-field-inner">
                    <input id="reg-confirm-password"
                           type="@(_showConfirmPassword ? "text" : "password")"
                           class="auth-field-input"
                           placeholder="••••••••"
                           autocomplete="new-password"
                           value="@model.ConfirmPassword"
                           @oninput="@(e => model.ConfirmPassword = e.Value?.ToString() ?? "")" />
                    <button type="button" class="pw-toggle" @onclick="ToggleConfirmPassword"
                            aria-label="@(_showConfirmPassword ? "Hide password" : "Show password")">
                        @if (_showConfirmPassword)
                        {
                            <svg viewBox="0 0 24 24" width="17" height="17" fill="none"
                                 stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                <line x1="1" y1="1" x2="23" y2="23"/>
                            </svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" width="17" height="17" fill="none"
                                 stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        }
                    </button>
                </div>
            </div>

            <!-- Terms -->
            <div class="auth-terms-row">
                <label class="auth-check-label" style="align-items: flex-start; margin-top: 2px;">
                    <input type="checkbox" class="auth-check" @bind="_termsAccepted" />
                    <span class="auth-check-box" aria-hidden="true" style="margin-top: 1px;">
                        <svg viewBox="0 0 12 10" width="11" height="9" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="1.5 5 4.5 8 10.5 2"/>
                        </svg>
                    </span>
                </label>
                <span class="auth-terms-text">
                    I agree to Momentum's <a href="#" class="auth-link" @onclick:preventDefault>Terms of Service</a>
                    and <a href="#" class="auth-link" @onclick:preventDefault>Privacy Policy</a>
                </span>
            </div>

            <!-- Submit -->
            <button type="submit" class="auth-submit" disabled="@busy">
                @if (busy)
                {
                    @("Creating account…")
                }
                else
                {
                    <span>Create account</span>
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none"
                         stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                }
            </button>

        </form>

        <!-- Bottom nav -->
        <p class="auth-bottom-nav">
            Already have an account? <a href="/login" class="auth-link">Sign in</a>
        </p>

    </div>

    <!-- Footer -->
    <footer class="auth-footer">
        Securely tracking momentum since 2025
        &nbsp;·&nbsp;<a href="#" class="auth-footer-link" @onclick:preventDefault>Privacy</a>
        &nbsp;·&nbsp;<a href="#" class="auth-footer-link" @onclick:preventDefault>Terms</a>
    </footer>

</div>

@code {
    private readonly RegisterRequest model = new();
    private IEnumerable<string> errors = [];
    private bool busy;
    private bool _showPassword;
    private bool _showConfirmPassword;
    private bool _termsAccepted;

    private void TogglePassword() => _showPassword = !_showPassword;
    private void ToggleConfirmPassword() => _showConfirmPassword = !_showConfirmPassword;

    private async Task HandleRegister()
    {
        // Client-side validation
        if (string.IsNullOrWhiteSpace(model.DisplayName) ||
            string.IsNullOrWhiteSpace(model.Email) ||
            string.IsNullOrWhiteSpace(model.Password) ||
            string.IsNullOrWhiteSpace(model.ConfirmPassword))
        {
            errors = ["Please fill in all fields."];
            return;
        }

        if (model.Password != model.ConfirmPassword)
        {
            errors = ["Passwords do not match."];
            return;
        }

        if (!_termsAccepted)
        {
            errors = ["Please accept the Terms of Service and Privacy Policy to continue."];
            return;
        }

        busy = true;
        errors = [];
        var result = await AuthService.RegisterAsync(model);
        busy = false;

        if (result.Succeeded)
            Navigation.NavigateTo("/");
        else
            errors = result.Errors;
    }
}
