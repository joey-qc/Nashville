@page "/log/detail"
@attribute [Authorize]
@inject ActivityLogService LogService
@inject CategoryService CategoryService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>View Log</PageTitle>

<div class="detail-page">

    <!-- ═══ Header ═══ -->
    <div class="detail-header">
        <div class="detail-title-row">
            <h1 class="detail-title">View Log</h1>
            <span class="detail-date">@DateDisplay</span>
        </div>

        @if (!_loading)
        {
            <p class="detail-stats">
                @FilteredLogs.Count() @(FilteredLogs.Count() == 1 ? "entry" : "entries")
                · <span class="stat-pos">+@Earned earned</span>
                @if (Setbacks > 0)
                {
                    <span class="stat-sep"> · </span>
                    <span class="stat-neg">-@Setbacks setbacks</span>
                }
                · <span class="@(NetTotal >= 0 ? "stat-pos" : "stat-neg")">@(NetTotal > 0 ? "+" : "")@NetTotal pts</span>
            </p>
        }
    </div>

    <!-- ═══ Filter bar ═══ -->
    <div class="filter-bar">

        <!-- Period pill -->
        <div class="period-pill">
            <span class="period-label">Period</span>
            <select class="period-select" @onchange="OnPeriodChanged">
                <option value="today"  selected="@(_period == "today")">Today</option>
                <option value="week"   selected="@(_period == "week")">This Week</option>
                <option value="month"  selected="@(_period == "month")">This Month</option>
            </select>
            <svg class="period-chevron" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                <path d="M7 10l5 5 5-5z" fill="currentColor"/>
            </svg>
        </div>

        <!-- Category filter chips -->
        <div class="cat-chips">
            <button type="button"
                    class="cat-chip @(_categoryFilter == null ? "active all" : "")"
                    @onclick="@(() => SetCategory(null))">
                <span class="chip-dot" style="background:#9E9E9E"></span>All
            </button>
            @foreach (var cat in _categories)
            {
                <button type="button"
                        class="cat-chip @(_categoryFilter == cat.Id ? "active" : "")"
                        style="@CatChipStyle(cat)"
                        title="@DimensionDisplayHelper.GetDisplayName(cat)"
                        @onclick="@(() => SetCategory(cat.Id))">
                    <span class="chip-dot" style="background:@cat.ColorHex"></span>
                    <span class="dim-full">@DimensionDisplayHelper.GetDisplayName(cat)</span>
                    <span class="dim-abbr" aria-hidden="true">@DimensionDisplayHelper.GetMobileLabel(cat)</span>
                </button>
            }
        </div>

    </div>

    <!-- ═══ Log list ═══ -->
    @if (_loading)
    {
        <div class="detail-loading">
            <p class="loading-text">Loading…</p>
        </div>
    }
    else if (!FilteredLogs.Any())
    {
        <div class="empty-state">
            @if (_logs.Any())
            {
                <p class="empty-text">No entries match that dimension.</p>
            }
            else
            {
                <p class="empty-text">No entries logged for this period.</p>
                <a href="/log" class="log-first-link">+ Log your first entry</a>
            }
        </div>
    }
    else
    {
        <div class="log-list">
            @foreach (var log in FilteredLogs)
            {
                <div class="log-card" @onclick="@(() => Navigation.NavigateTo($"/log?editId={log.Id}"))">

                    <!-- Badge -->
                    <div class="log-badge" style="background:@BadgeBg(log);color:@BadgeColor(log)">
                        @(string.IsNullOrEmpty(log.ActivityName) ? "?" : log.ActivityName[..1].ToUpper())
                    </div>

                    <!-- Name + category tags -->
                    <div class="log-info">
                        <span class="log-name" title="@log.ActivityName">@log.ActivityName</span>
                        <div class="log-cats">
                            @foreach (var cat in log.Categories)
                            {
                                <span class="log-cat-dot" style="background:@cat.ColorHex"></span>
                                <span class="log-cat-label" title="@DimensionDisplayHelper.GetDisplayName(cat)">
                                    <span class="dim-full">@DimensionDisplayHelper.GetDisplayName(cat)</span>
                                    <span class="dim-abbr" aria-hidden="true">@DimensionDisplayHelper.GetMobileLabel(cat)</span>
                                </span>
                            }
                        </div>
                    </div>

                    <!-- Time + points -->
                    <div class="log-right">
                        <span class="log-time">@LogTimestamp(log)</span>
                        <span class="log-pts @(log.PointsRecorded >= 0 ? "pos" : "neg")">
                            @(log.PointsRecorded > 0 ? "+" : "")@log.PointsRecorded
                        </span>
                    </div>

                    <!-- Delete controls -->
                    <div class="log-actions" @onclick:stopPropagation>
                        @if (_pendingDeleteId == log.Id)
                        {
                            <button type="button" class="act-btn confirm" title="Confirm delete"
                                    @onclick="@(() => ConfirmDelete(log.Id))">
                                <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" fill="currentColor"/>
                                </svg>
                            </button>
                            <button type="button" class="act-btn cancel-del" title="Cancel"
                                    @onclick="@(() => _pendingDeleteId = null)">
                                <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                    <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/>
                                </svg>
                            </button>
                        }
                        else
                        {
                            <button type="button" class="act-btn delete" title="Delete"
                                    @onclick="@(() => _pendingDeleteId = log.Id)">
                                <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                    <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="currentColor"/>
                                </svg>
                            </button>
                        }
                    </div>

                </div>
            }
        </div>
    }

</div>

@code {
    [SupplyParameterFromQuery] private string? Period { get; set; }

    private string _period = "today";
    private List<ActivityLogDto> _logs = [];
    private List<CategoryDto> _categories = [];
    private int? _categoryFilter;
    private bool _loading;
    private int? _pendingDeleteId;

    private string DateDisplay => DateTime.Now.ToString("d MMM ddd");

    private IEnumerable<ActivityLogDto> FilteredLogs =>
        _categoryFilter.HasValue
            ? _logs.Where(l => l.Categories.Any(c => c.Id == _categoryFilter))
            : _logs;

    private int Earned   => FilteredLogs.Where(l => l.PointsRecorded > 0).Sum(l => l.PointsRecorded);
    private int Setbacks => Math.Abs(FilteredLogs.Where(l => l.PointsRecorded < 0).Sum(l => l.PointsRecorded));
    private int NetTotal => FilteredLogs.Sum(l => l.PointsRecorded);

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Period))
            _period = Period;
        _categories = (await CategoryService.GetAllAsync()).ToList();
        await LoadLogs();
    }

    private async Task OnPeriodChanged(ChangeEventArgs e)
    {
        _period = e.Value?.ToString() ?? "today";
        await LoadLogs();
    }

    private void SetCategory(int? id) => _categoryFilter = id;

    private async Task LoadLogs()
    {
        _loading = true;
        _pendingDeleteId = null;
        var (from, to) = GetDateRange();
        _logs = await LogService.GetByDateRangeAsync(from, to);
        _loading = false;
    }

    private (DateTime from, DateTime to) GetDateRange()
    {
        // DateTime.Today is the browser's local midnight (DateTimeKind.Local).
        // ToUniversalTime() converts to the correct UTC equivalent so the API
        // query uses inclusive-start / exclusive-end UTC boundaries that align
        // with the user's local calendar day rather than UTC midnight.
        var localToday = DateTime.Today;
        var toUtc      = localToday.AddDays(1).ToUniversalTime();
        return _period switch
        {
            "week"  => (localToday.AddDays(-(int)localToday.DayOfWeek).ToUniversalTime(), toUtc),
            "month" => (localToday.AddDays(1 - localToday.Day).ToUniversalTime(),         toUtc),
            _       => (localToday.ToUniversalTime(),                                      toUtc)
        };
    }

    private async Task ConfirmDelete(int id)
    {
        _pendingDeleteId = null;
        var success = await LogService.DeleteAsync(id);
        if (success)
        {
            Snackbar.Add("Log entry deleted.", Severity.Success);
            await LoadLogs();
        }
        else
        {
            Snackbar.Add("Failed to delete entry.", Severity.Error);
        }
    }

    private string LogTimestamp(ActivityLogDto log)
    {
        var local = log.LoggedAt.ToLocalTime();
        return _period == "today"
            ? local.ToString("h:mm tt")
            : local.ToString("MMM d") + " · " + local.ToString("h:mm tt");
    }

    private static string BadgeBg(ActivityLogDto log) =>
        log.Categories.Count > 0 ? $"{log.Categories[0].ColorHex}26" : "#4A608026";

    private static string BadgeColor(ActivityLogDto log) =>
        log.Categories.Count > 0 ? log.Categories[0].ColorHex : "#4A6080";

    private string CatChipStyle(CategoryDto cat) =>
        _categoryFilter == cat.Id
            ? $"background:{cat.ColorHex}26;border-color:{cat.ColorHex};color:{cat.ColorHex}"
            : "";
}
