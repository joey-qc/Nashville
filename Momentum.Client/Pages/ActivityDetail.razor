@page "/log/detail"
@attribute [Authorize]
@inject ActivityLogService LogService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>View Log</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">View Log</MudText>

<div class="d-flex align-center mb-4">
    <div style="width:60%">
        <MudSelect T="string" Label="Period" @bind-Value="_period" @bind-Value:after="LoadLogs">
            <MudSelectItem Value='"today"'>Today</MudSelectItem>
            <MudSelectItem Value='"week"'>This Week</MudSelectItem>
            <MudSelectItem Value='"month"'>This Month</MudSelectItem>
        </MudSelect>
    </div>
    <div class="d-flex justify-end" style="width:40%">
        <MudFab Color="MudBlazor.Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                Href="/log" Label="Add Entry" />
    </div>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (!_logs.Any())
{
    <MudText Color="MudBlazor.Color.Secondary">No activities logged for this period.</MudText>
}
else
{
    @foreach (var log in _logs)
    {
        <MudPaper Class="pa-3 mb-2">
            <div class="d-flex justify-space-between align-center mb-1">
                <MudText><strong>@log.ActivityName</strong></MudText>
                <MudText Color="@(log.PointsRecorded >= 0 ? MudBlazor.Color.Success : MudBlazor.Color.Error)">
                    @(log.PointsRecorded > 0 ? "+" : "")@log.PointsRecorded
                </MudText>
            </div>
            <div class="mb-1">
                @foreach (var cat in log.Categories)
                {
                    <MudChip T="string" Size="MudBlazor.Size.Small"
                             Style="@($"background:{cat.ColorHex};color:white")"
                             Class="mr-1">@cat.Name</MudChip>
                }
            </div>
            <div class="d-flex justify-space-between align-center">
                <MudText Typo="Typo.caption">@log.LoggedAt.ToLocalTime().ToString("MMM d, h:mm tt")</MudText>
                <div class="d-flex flex-nowrap align-center">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="MudBlazor.Size.Small"
                                   OnClick="@(() => Navigation.NavigateTo($"/log?editId={log.Id}"))" />
                    @if (_pendingDeleteId == log.Id)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Check" Size="MudBlazor.Size.Small"
                                       Color="MudBlazor.Color.Error"
                                       OnClick="@(() => ConfirmDelete(log.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="MudBlazor.Size.Small"
                                       OnClick="@(() => _pendingDeleteId = null)" />
                    }
                    else
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="MudBlazor.Size.Small"
                                       Color="MudBlazor.Color.Error"
                                       OnClick="@(() => _pendingDeleteId = log.Id)" />
                    }
                </div>
            </div>
        </MudPaper>
    }
    <MudText Align="MudBlazor.Align.Right" Class="mt-2">
        <strong>Total: @_logs.Sum(l => l.PointsRecorded) pts</strong>
    </MudText>
}

@code {
    [SupplyParameterFromQuery] private string? Period { get; set; }

    private string _period = "today";
    private List<ActivityLogDto> _logs = [];
    private bool _loading;
    private int? _pendingDeleteId;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Period))
            _period = Period;
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        _loading = true;
        _pendingDeleteId = null;
        var (from, to) = GetDateRange();
        _logs = await LogService.GetByDateRangeAsync(from, to);
        _loading = false;
    }

    private (DateTime from, DateTime to) GetDateRange()
    {
        var now = DateTime.UtcNow;
        return _period switch
        {
            "week" => (now.Date.AddDays(-(int)now.DayOfWeek), now.Date.AddDays(1)),
            "month" => (new DateTime(now.Year, now.Month, 1), now.Date.AddDays(1)),
            _ => (now.Date, now.Date.AddDays(1))
        };
    }

    private async Task ConfirmDelete(int id)
    {
        _pendingDeleteId = null;
        var success = await LogService.DeleteAsync(id);
        if (success)
        {
            Snackbar.Add("Log entry deleted.", Severity.Success);
            await LoadLogs();
        }
        else
        {
            Snackbar.Add("Failed to delete entry.", Severity.Error);
        }
    }
}
