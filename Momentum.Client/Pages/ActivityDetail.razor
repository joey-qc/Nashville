@page "/log/detail"
@attribute [Authorize]
@inject ActivityLogService LogService
@inject CategoryService CategoryService
@inject CheckInService CheckInService
@inject NavigationManager Navigation
@inject ToastService Toast

<PageTitle>View Log</PageTitle>

<div class="detail-page">

    <!-- ═══ Header ═══ -->
    <div class="detail-header">
        <div class="detail-title-row">
            <h1 class="detail-title">View Log</h1>
            <span class="detail-date">@DateDisplay</span>
        </div>

        @if (!_loading)
        {
            <div class="detail-stats-row">
                <p class="detail-stats">
                    @FilteredLogs.Count() @(FilteredLogs.Count() == 1 ? "entry" : "entries")
                    · <span class="stat-pos">+@Earned earned</span>
                    @if (Setbacks > 0)
                    {
                        <span class="stat-sep"> · </span>
                        <span class="stat-neg">-@Setbacks setbacks</span>
                    }
                    · <span class="@(NetTotal >= 0 ? "stat-pos" : "stat-neg")">@(NetTotal > 0 ? "+" : "")@NetTotal pts</span>
                </p>

                <!-- Details toggle — reveals notes, linked check-ins, standalone check-ins -->
                @if (FilteredLogs.Any() || _standaloneCheckIns.Any())
                {
                    <button type="button"
                            class="details-toggle @(_showDetails ? "active" : "")"
                            aria-pressed="@(_showDetails ? "true" : "false")"
                            aria-label="@(_showDetails ? "Hide details" : "Show details")"
                            title="@(_showDetails ? "Hide details" : "Show details")"
                            @onclick="@(() => _showDetails = !_showDetails)">
                        <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"
                             fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h13a2 2 0 0 1 2 2v14a2 2 0 0 0-2-2H4z"/>
                            <line x1="8" y1="8" x2="14" y2="8"/>
                            <line x1="8" y1="12" x2="14" y2="12"/>
                        </svg>
                        Details
                    </button>
                }
            </div>
        }
    </div>

    <!-- ═══ Filter bar ═══ -->
    <div class="filter-bar">

        <!-- Period pill + anchor date picker on the same row -->
        <div class="period-controls">
            <div class="period-pill">
                <span class="period-label">Period</span>
                <select class="period-select" @onchange="OnPeriodChanged">
                    <option value="today"  selected="@(_period == "today")">Today</option>
                    <option value="week"   selected="@(_period == "week")">This Week</option>
                    <option value="month"  selected="@(_period == "month")">This Month</option>
                </select>
                <svg class="period-chevron" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                    <path d="M7 10l5 5 5-5z" fill="currentColor"/>
                </svg>
            </div>
            <label class="date-pill">
                <input type="date" class="date-input"
                       value="@_anchorStr"
                       max="@_todayStr"
                       aria-label="Select anchor date"
                       @onchange="OnAnchorChanged" />
            </label>
        </div>

        <!-- Category filter chips -->
        <div class="cat-chips">
            <button type="button"
                    class="cat-chip @(_categoryFilter == null ? "active all" : "")"
                    @onclick="@(() => SetCategory(null))">
                <span class="chip-dot" style="background:#9E9E9E"></span>All
            </button>
            @foreach (var cat in _categories)
            {
                <button type="button"
                        class="cat-chip @(_categoryFilter == cat.Id ? "active" : "")"
                        style="@CatChipStyle(cat)"
                        title="@DimensionDisplayHelper.GetDisplayName(cat)"
                        @onclick="@(() => SetCategory(cat.Id))">
                    <span class="chip-dot" style="background:@cat.ColorHex"></span>
                    <span class="dim-full">@DimensionDisplayHelper.GetDisplayName(cat)</span>
                    <span class="dim-abbr" aria-hidden="true">@DimensionDisplayHelper.GetMobileLabel(cat)</span>
                </button>
            }
        </div>

    </div>

    <!-- ═══ Log list ═══ -->
    @if (_loading)
    {
        <div class="detail-loading">
            <p class="loading-text">Loading…</p>
        </div>
    }
    else if (IsEmpty)
    {
        <div class="empty-state">
            @if (_logs.Any())
            {
                <p class="empty-text">No entries match that dimension.</p>
            }
            else
            {
                <p class="empty-text">No entries logged for this period.</p>
                <a href="/log" class="log-first-link">+ Log your first entry</a>
            }
        </div>
    }
    else
    {
        <div class="log-list">
            @foreach (var item in TimelineItems)
            {
                @if (item.Log is { } log)
                {
                    <div class="log-card">

                        <!-- Clickable row → edit -->
                        <div class="log-card-row" @onclick="@(() => Navigation.NavigateTo($"/log?editId={log.Id}"))">

                            <!-- Badge -->
                            <div class="log-badge" style="background:@BadgeBg(log);color:@BadgeColor(log)">
                                @(string.IsNullOrEmpty(log.ActivityName) ? "?" : log.ActivityName[..1].ToUpper())
                            </div>

                            <!-- Name + category tags -->
                            <div class="log-info">
                                <span class="log-name" title="@log.ActivityName">@log.ActivityName</span>
                                <div class="log-cats">
                                    @foreach (var cat in log.Categories)
                                    {
                                        <span class="log-cat-dot" style="background:@cat.ColorHex"></span>
                                        <span class="log-cat-label" title="@DimensionDisplayHelper.GetDisplayName(cat)">
                                            <span class="dim-full">@DimensionDisplayHelper.GetDisplayName(cat)</span>
                                            <span class="dim-abbr" aria-hidden="true">@DimensionDisplayHelper.GetMobileLabel(cat)</span>
                                        </span>
                                    }
                                </div>
                            </div>

                            <!-- Time + points -->
                            <div class="log-right">
                                <span class="log-time">@LogTimestamp(log)</span>
                                <span class="log-pts @(log.PointsRecorded >= 0 ? "pos" : "neg")">
                                    @(log.PointsRecorded > 0 ? "+" : "")@log.PointsRecorded
                                </span>
                            </div>

                            <!-- Delete controls -->
                            <div class="log-actions" @onclick:stopPropagation>
                                @if (_pendingDeleteId == log.Id)
                                {
                                    <button type="button" class="act-btn confirm" title="Confirm delete"
                                            @onclick="@(() => ConfirmDelete(log.Id))">
                                        <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" fill="currentColor"/>
                                        </svg>
                                    </button>
                                    <button type="button" class="act-btn cancel-del" title="Cancel"
                                            @onclick="@(() => _pendingDeleteId = null)">
                                        <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/>
                                        </svg>
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="act-btn delete" title="Delete"
                                            @onclick="@(() => _pendingDeleteId = log.Id)">
                                        <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                            <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="currentColor"/>
                                        </svg>
                                    </button>
                                }
                            </div>

                        </div>

                        <!-- Details (notes + linked check-ins + add action) when toggle ON -->
                        @if (_showDetails)
                        {
                            @if (!string.IsNullOrWhiteSpace(log.Notes))
                            {
                                <div class="log-note-body">@((MarkupString)log.Notes!)</div>
                            }

                            <div class="log-checkins">
                                @foreach (var ci in CheckInsFor(log.Id))
                                {
                                    <div class="ci-row">
                                        <button type="button" class="ci-main"
                                                title="Edit check-in"
                                                @onclick="@(() => Navigation.NavigateTo($"/check-ins?editId={ci.Id}&returnUrl={ReturnUrl}"))">
                                            <span class="ci-time">@CheckInTime(ci)</span>
                                            <span class="ci-scores">
                                                <span class="ci-metric">B
                                                    <span class="ci-val @ScoreClass(ci.BodyScore)">@Signed(ci.BodyScore)</span>
                                                </span>
                                                <span class="ci-metric">E
                                                    <span class="ci-val @ScoreClass(ci.EnergyScore)">@Signed(ci.EnergyScore)</span>
                                                </span>
                                                <span class="ci-metric">M
                                                    <span class="ci-val @ScoreClass(ci.MoodScore)">@Signed(ci.MoodScore)</span>
                                                </span>
                                            </span>
                                        </button>
                                        <div class="ci-del">
                                            @if (_pendingCheckInDeleteId == ci.Id)
                                            {
                                                <button type="button" class="act-btn confirm" title="Confirm delete"
                                                        @onclick="@(() => ConfirmDeleteCheckIn(ci.Id))">
                                                    <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" fill="currentColor"/>
                                                    </svg>
                                                </button>
                                                <button type="button" class="act-btn cancel-del" title="Cancel"
                                                        @onclick="@(() => _pendingCheckInDeleteId = null)">
                                                    <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                                        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/>
                                                    </svg>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="act-btn delete" title="Delete check-in"
                                                        @onclick="@(() => _pendingCheckInDeleteId = ci.Id)">
                                                    <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                                        <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="currentColor"/>
                                                    </svg>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }

                                <button type="button" class="ci-add" @onclick="@(() => AddCheckIn(log))">
                                    + Add Check-In
                                </button>
                            </div>
                        }

                    </div>
                }
                else if (item.CheckIn is { } ci)
                {
                    <!-- ══ Standalone Check-In top-level row (Details ON only) ══ -->
                    <div class="log-card">
                        <div class="log-card-row" @onclick="@(() => Navigation.NavigateTo($"/check-ins?editId={ci.Id}&returnUrl={ReturnUrl}"))">

                            <!-- Badge: heart icon, neutral surface style -->
                            <div class="log-badge ci-badge">
                                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="currentColor"/>
                                </svg>
                            </div>

                            <!-- Title + B/E/M scores as second line -->
                            <div class="log-info">
                                <span class="log-name">Check-In</span>
                                <div class="log-cats">
                                    <span class="ci-metric">B <span class="ci-val @ScoreClass(ci.BodyScore)">@Signed(ci.BodyScore)</span></span>
                                    <span class="ci-metric">E <span class="ci-val @ScoreClass(ci.EnergyScore)">@Signed(ci.EnergyScore)</span></span>
                                    <span class="ci-metric">M <span class="ci-val @ScoreClass(ci.MoodScore)">@Signed(ci.MoodScore)</span></span>
                                </div>
                            </div>

                            <!-- Time only (standalone check-ins have no points) -->
                            <div class="log-right">
                                <span class="log-time">@StandaloneCheckInTimestamp(ci)</span>
                            </div>

                            <!-- Delete controls -->
                            <div class="log-actions" @onclick:stopPropagation>
                                @if (_pendingCheckInDeleteId == ci.Id)
                                {
                                    <button type="button" class="act-btn confirm" title="Confirm delete"
                                            @onclick="@(() => ConfirmDeleteCheckIn(ci.Id))">
                                        <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" fill="currentColor"/>
                                        </svg>
                                    </button>
                                    <button type="button" class="act-btn cancel-del" title="Cancel"
                                            @onclick="@(() => _pendingCheckInDeleteId = null)">
                                        <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/>
                                        </svg>
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="act-btn delete" title="Delete check-in"
                                            @onclick="@(() => _pendingCheckInDeleteId = ci.Id)">
                                        <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                            <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="currentColor"/>
                                        </svg>
                                    </button>
                                }
                            </div>

                        </div>
                    </div>
                }
            }
        </div>
    }

</div>

@code {
    [SupplyParameterFromQuery] private string? Period { get; set; }
    // When returning from an add/edit check-in flow, this restores the expanded Details state.
    [SupplyParameterFromQuery(Name = "details")] private string? DetailsParam { get; set; }
    // Anchor date passed back via returnUrl so browsing context is preserved.
    [SupplyParameterFromQuery(Name = "anchor")]  private string? AnchorParam { get; set; }

    private string _period = "today";
    private DateTime _anchor = DateTime.Today;
    private string _anchorStr => _anchor.ToString("yyyy-MM-dd");
    private string _todayStr  => DateTime.Today.ToString("yyyy-MM-dd");
    private List<ActivityLogDto> _logs = [];
    private List<CategoryDto> _categories = [];
    private int? _categoryFilter;
    private bool _loading;
    private int? _pendingDeleteId;
    private bool _showDetails;

    // Linked check-ins keyed by ActivityLogId (user-scoped; loaded with the logs).
    private Dictionary<int, List<CheckInDto>> _checkInsByLog = [];
    // Standalone check-ins in the current period (ActivityLogId == null), for the unified timeline.
    private List<CheckInDto> _standaloneCheckIns = [];
    private int? _pendingCheckInDeleteId;

    // Discriminated-union timeline item used by the Details-mode unified timeline.
    private sealed record TimelineItem(ActivityLogDto? Log, CheckInDto? CheckIn, DateTime SortKey);

    // Show date range in header based on selected period and anchor.
    private string DateDisplay => _period switch
    {
        "week"  => $"{_anchor.AddDays(-6):MMM d} – {_anchor:MMM d}",
        "month" => $"{_anchor.AddDays(-29):MMM d} – {_anchor:MMM d}",
        _       => _anchor.ToString("d MMM ddd")
    };

    private IEnumerable<ActivityLogDto> FilteredLogs =>
        _categoryFilter.HasValue
            ? _logs.Where(l => l.Categories.Any(c => c.Id == _categoryFilter))
            : _logs;

    // Empty when: Details OFF → no filtered logs; Details ON → no filtered logs AND no standalone check-ins.
    // Standalone check-ins are date-filtered but not dimension-filtered, so they keep the timeline
    // non-empty even when a dimension filter hides all activity logs.
    private bool IsEmpty => _showDetails
        ? !FilteredLogs.Any() && !_standaloneCheckIns.Any()
        : !FilteredLogs.Any();

    // When Details OFF: activity logs only (preserves existing compact-mode order from the API).
    // When Details ON: activity logs + standalone check-ins merged, newest first by sort key.
    private IEnumerable<TimelineItem> TimelineItems
    {
        get
        {
            var logItems = FilteredLogs.Select(l => new TimelineItem(l, null, l.LoggedAt));
            if (!_showDetails) return logItems;
            var ciItems = _standaloneCheckIns.Select(c => new TimelineItem(null, c, c.CheckedInAt));
            return logItems.Concat(ciItems).OrderByDescending(t => t.SortKey);
        }
    }

    private int Earned   => FilteredLogs.Where(l => l.PointsRecorded > 0).Sum(l => l.PointsRecorded);
    private int Setbacks => Math.Abs(FilteredLogs.Where(l => l.PointsRecorded < 0).Sum(l => l.PointsRecorded));
    private int NetTotal => FilteredLogs.Sum(l => l.PointsRecorded);

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Period))
            _period = Period;
        if (!string.IsNullOrEmpty(AnchorParam) && DateTime.TryParse(AnchorParam, out var parsed))
            _anchor = parsed.Date <= DateTime.Today ? parsed.Date : DateTime.Today;
        // Restore expanded Details when returning from an add/edit check-in flow.
        _showDetails = DetailsParam == "true";
        _categories = (await CategoryService.GetAllAsync()).ToList();
        await LoadLogs();
    }

    // Encoded return target so add/edit check-in flows can come back to this exact
    // View Log context (same period, anchor date, Details expanded). Generic returnUrl pattern.
    private string ReturnUrl =>
        Uri.EscapeDataString($"/log/detail?period={_period}&anchor={_anchorStr}&details=true");

    private async Task OnPeriodChanged(ChangeEventArgs e)
    {
        _period = e.Value?.ToString() ?? "today";
        await LoadLogs();
    }

    private async Task OnAnchorChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var d))
            _anchor = d.Date <= DateTime.Today ? d.Date : DateTime.Today;
        else
            _anchor = DateTime.Today;
        await LoadLogs();
    }

    private void SetCategory(int? id) => _categoryFilter = id;

    private async Task LoadLogs()
    {
        _loading = true;
        _pendingDeleteId = null;
        _pendingCheckInDeleteId = null;
        var (from, to) = GetDateRange();
        _logs = await LogService.GetByDateRangeAsync(from, to);

        // Load all user check-ins (user-scoped, UTC-tagged).
        var checkIns = await CheckInService.GetAllAsync();

        // Linked check-ins: grouped by ActivityLogId for display under their parent entries.
        // Uses the full set (not period-filtered) since a check-in's date may differ from its
        // parent log's date (e.g., logged late-night, checked in just after midnight).
        _checkInsByLog = checkIns
            .Where(c => c.ActivityLogId.HasValue)
            .GroupBy(c => c.ActivityLogId!.Value)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(c => c.CheckedInAt).ToList());

        // Standalone check-ins: no linked activity log, filtered to the current date period.
        // These appear as top-level timeline rows when Details is ON.
        _standaloneCheckIns = checkIns
            .Where(c => !c.ActivityLogId.HasValue
                     && c.CheckedInAt >= from
                     && c.CheckedInAt < to)
            .OrderByDescending(c => c.CheckedInAt)
            .ToList();

        _loading = false;
    }

    private List<CheckInDto> CheckInsFor(int logId) =>
        _checkInsByLog.TryGetValue(logId, out var list) ? list : [];

    private (DateTime from, DateTime to) GetDateRange()
    {
        // _anchor is a local calendar date. Convert boundaries to UTC so the API
        // query uses inclusive-start / exclusive-end UTC ranges aligned to the
        // user's local calendar day. Rolling windows: Day=1d, Week=7d, Month=30d.
        var anchor = _anchor.Date;
        var to     = anchor.AddDays(1).ToUniversalTime();
        return _period switch
        {
            "week"  => (anchor.AddDays(-6).ToUniversalTime(),  to),
            "month" => (anchor.AddDays(-29).ToUniversalTime(), to),
            _       => (anchor.ToUniversalTime(),               to)
        };
    }

    private async Task ConfirmDelete(int id)
    {
        _pendingDeleteId = null;
        var success = await LogService.DeleteAsync(id);
        if (success)
        {
            Toast.Show("Log entry deleted.", ToastType.Success);
            await LoadLogs();
        }
        else
        {
            Toast.Show("Failed to delete entry.", ToastType.Error);
        }
    }

    private string LogTimestamp(ActivityLogDto log)
    {
        var local = log.LoggedAt.ToLocalTime();
        // Day period = single date → show time only. Week/Month → show date + time.
        return _period == "today"
            ? local.ToString("h:mm tt")
            : local.ToString("MMM d") + " · " + local.ToString("h:mm tt");
    }

    // ── Linked check-ins ──────────────────────────────────────────────────────

    private static string CheckInTime(CheckInDto ci)
    {
        var local = ci.CheckedInAt.ToLocalTime();
        return local.ToString("MMM d") + " · " + local.ToString("h:mm tt");
    }

    // Standalone check-in timestamp mirrors LogTimestamp: time-only for Today, date+time otherwise.
    private string StandaloneCheckInTimestamp(CheckInDto ci)
    {
        var local = ci.CheckedInAt.ToLocalTime();
        return _period == "today"
            ? local.ToString("h:mm tt")
            : local.ToString("MMM d") + " · " + local.ToString("h:mm tt");
    }

    private static string Signed(int v) => v > 0 ? $"+{v}" : v.ToString();

    private static string ScoreClass(int v) => v > 0 ? "pos" : v < 0 ? "neg" : "";

    private void AddCheckIn(ActivityLogDto log) =>
        Navigation.NavigateTo(
            $"/check-in?activityLogId={log.Id}&from={Uri.EscapeDataString(log.ActivityName)}&returnUrl={ReturnUrl}");

    private async Task ConfirmDeleteCheckIn(int id)
    {
        _pendingCheckInDeleteId = null;
        var success = await CheckInService.DeleteAsync(id);
        if (success)
        {
            Toast.Show("Check-in deleted.", ToastType.Success);
            await LoadLogs();
        }
        else
        {
            Toast.Show("Failed to delete check-in.", ToastType.Error);
        }
    }

    private static string BadgeBg(ActivityLogDto log) =>
        log.Categories.Count > 0 ? $"{log.Categories[0].ColorHex}26" : "#4A608026";

    private static string BadgeColor(ActivityLogDto log) =>
        log.Categories.Count > 0 ? log.Categories[0].ColorHex : "#4A6080";

    private string CatChipStyle(CategoryDto cat) =>
        _categoryFilter == cat.Id
            ? $"background:{cat.ColorHex}26;border-color:{cat.ColorHex};color:{cat.ColorHex}"
            : "";
}
