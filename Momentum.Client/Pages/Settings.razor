@page "/settings"
@attribute [Authorize]
@inject UserSettingsService SettingsService
@inject ISnackbar Snackbar

<PageTitle>Settings</PageTitle>

<div class="settings-page">

    <!-- ═══ Page header ═══ -->
    <header class="settings-header">
        <span class="kicker">ACCOUNT</span>
        <h1 class="settings-title">Settings</h1>
        <p class="settings-subtitle">Manage your profile and how Momentum knows you.</p>
    </header>

    <!-- ═══ Loading state ═══ -->
    @if (_settings is null)
    {
        <div class="settings-loading">
            <p class="loading-text">Loading…</p>
        </div>
    }
    else
    {
        <!-- ═══ Profile card ═══ -->
        <div class="settings-card">

            <!-- Card header: title + avatar -->
            <div class="card-top">
                <div class="card-intro">
                    <h2 class="card-title">Profile</h2>
                    <p class="card-desc">Your identity inside Momentum.</p>
                </div>
                <div class="profile-avatar">
                    <span class="avatar-initial">
                        @char.ToUpper((_displayName.Length > 0 ? _displayName[0] : _settings.Email[0]))
                    </span>
                </div>
            </div>

            <hr class="card-divider" />

            <!-- Fields -->
            <div class="card-body">

                <!-- Email (read-only) -->
                <div class="field-group">
                    <label class="field-label">EMAIL</label>
                    <div class="readonly-field">
                        <span class="readonly-value">@_settings.Email</span>
                        <span class="verified-badge">VERIFIED</span>
                    </div>
                    <p class="field-helper">Email is tied to your account and can't be edited here.</p>
                </div>

                <!-- Display Name -->
                <div class="field-group">
                    <label class="field-label" for="setting-display-name">DISPLAY NAME</label>
                    <input id="setting-display-name"
                           type="text"
                           class="field-input"
                           placeholder="Your name"
                           maxlength="100"
                           value="@_displayName"
                           @oninput="@(e => _displayName = e.Value?.ToString() ?? "")" />
                </div>

            </div>

            <hr class="card-divider" />

            <!-- Save action -->
            <div class="card-footer">
                <button type="button" class="btn-save" disabled="@_saving" @onclick="SaveSettings">
                    @(_saving ? "Saving…" : "Save changes")
                </button>
            </div>

        </div>
    }

</div>

@code {
    private UserSettingsDto? _settings;
    private string _displayName = string.Empty;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.GetAsync();
        if (_settings is not null)
            _displayName = _settings.DisplayName;
    }

    private async Task SaveSettings()
    {
        _saving = true;
        var result = await SettingsService.UpdateAsync(new UpdateUserSettingsDto
        {
            DisplayName = _displayName
        });
        _saving = false;

        if (result is not null)
        {
            _settings = result;
            Snackbar.Add("Settings saved.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to save settings.", Severity.Error);
        }
    }
}
