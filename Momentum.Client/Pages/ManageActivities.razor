@page "/activities"
@attribute [Authorize]
@inject ActivityService ActivityService
@inject CategoryService CategoryService
@inject ToastService Toast
@inject IJSRuntime JS

<PageTitle>Manage Activities</PageTitle>

<div class="activities-page">

    <!-- ═══ Page header ═══ -->
    <header class="act-header">
        <div>
            <span class="kicker">LIBRARY</span>
            <h1 class="act-title">Manage Activities</h1>
            <p class="act-subtitle">
                @_activities.Count @(_activities.Count == 1 ? "activity" : "activities")
                &nbsp;·&nbsp;@_categories.Count dimensions
                &nbsp;·&nbsp;tap any row to edit
            </p>
        </div>
        <button class="btn-new-activity" @onclick="OpenCreateForm" type="button">
            <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"
                 fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <path d="M12 5v14M5 12h14"/>
            </svg>
            New Activity
        </button>
    </header>

    <!-- ═══ Search bar ═══ -->
    <label class="search-bar">
        <svg class="search-icon" viewBox="0 0 24 24" width="17" height="17" aria-hidden="true"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="11" cy="11" r="7"/>
            <path d="m16.5 16.5 4.5 4.5"/>
        </svg>
        <input type="text"
               class="search-input"
               placeholder="Search activities…"
               value="@_search"
               @oninput="@(e => _search = e.Value?.ToString() ?? "")"
               autocomplete="off" />
        <span class="search-count">
            @FilteredActivities.Count() @(FilteredActivities.Count() == 1 ? "result" : "results")
        </span>
    </label>

    <!-- ═══ Activity table ═══ -->
    @if (_loading)
    {
        <div class="act-loading">
            <p class="loading-text">Loading activities…</p>
        </div>
    }
    else if (!_activities.Any())
    {
        <div class="activities-card">
            <div class="empty-state">
                <p class="empty-text">No activities yet. Tap <strong>+ New Activity</strong> to add your first one.</p>
            </div>
        </div>
    }
    else
    {
        <div class="activities-card">

            <!-- Column headers -->
            <div class="table-head">
                <span class="col-h">NAME</span>
                <span class="col-h cats-head">DIMENSIONS</span>
                <span class="col-h pts-head">DEFAULT POINTS</span>
                <span class="col-h actions-head">ACTIONS</span>
            </div>

            <!-- Activity rows -->
            @foreach (var activity in FilteredActivities)
            {
                var a = activity;
                <div class="act-row" @onclick="@(async () => await OpenEditForm(a))">

                    <!-- Name column -->
                    <div class="row-name">
                        <div class="act-badge" style="background:@BadgeBg(a);color:@BadgeColor(a)">
                            @* TODO: Replace with shared CategoryIcon component once CR #1 (Iconography) is implemented *@
                            @char.ToUpper(a.Name[0])
                        </div>
                        <span class="act-name">@a.Name</span>
                    </div>

                    <!-- Categories column -->
                    <div class="row-cats">
                        @foreach (var cat in a.Categories)
                        {
                            <span class="row-cat-chip" title="@DimensionDisplayHelper.GetDisplayName(cat)">
                                <span class="row-cat-dot" style="background:@cat.ColorHex"></span>
                                <span class="dim-full">@DimensionDisplayHelper.GetDisplayName(cat)</span>
                                <span class="dim-abbr" aria-hidden="true">@DimensionDisplayHelper.GetMobileLabel(cat)</span>
                            </span>
                        }
                    </div>

                    <!-- Points column -->
                    <div class="row-pts @(a.DefaultPoints >= 0 ? "pos" : "neg")">
                        @(a.DefaultPoints > 0 ? "+" : "")@a.DefaultPoints
                    </div>

                    <!-- Actions — stopPropagation prevents the row-click from also firing -->
                    <div class="row-actions" @onclick:stopPropagation>
                        @if (_pendingDeleteActivityId == a.Id)
                        {
                            <button class="act-btn confirm" type="button"
                                    title="Confirm delete"
                                    @onclick="@(async () => await DeleteActivity(a))"
                                    @onclick:stopPropagation="true">
                                <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" fill="currentColor"/>
                                </svg>
                            </button>
                            <button class="act-btn cancel-del" type="button"
                                    title="Cancel"
                                    @onclick="@(() => _pendingDeleteActivityId = null)"
                                    @onclick:stopPropagation="true">
                                <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                    <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/>
                                </svg>
                            </button>
                        }
                        else
                        {
                            <button class="icon-btn trash-btn" type="button"
                                    title="Delete activity"
                                    @onclick="@(() => _pendingDeleteActivityId = a.Id)"
                                    @onclick:stopPropagation="true">
                                <svg viewBox="0 0 24 24" width="15" height="15" fill="none"
                                     stroke="currentColor" stroke-width="1.8"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="3 6 5 6 21 6"/>
                                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                                    <path d="M10 11v6M14 11v6"/>
                                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                                </svg>
                            </button>
                        }
                    </div>

                </div>
            }

            @if (!FilteredActivities.Any())
            {
                <div class="empty-filtered">
                    <p class="empty-text">No activities match "<em>@_search</em>"</p>
                </div>
            }

        </div>
    }

</div>

<!-- ═══ Edit / New Activity modal ═══ -->
@if (_showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card" @onclick:stopPropagation="true">

            <div class="modal-header">
                <div class="modal-title-group">
                    <span class="modal-kicker">@(_editingId.HasValue ? "EDITING" : "LIBRARY")</span>
                    <h2 class="modal-title">@(_editingId.HasValue ? (_editingActivity?.Name ?? "Activity") : "New Activity")</h2>
                </div>
                <button class="modal-close-btn" type="button" @onclick="CloseForm" aria-label="Close">
                    <svg viewBox="0 0 24 24" width="17" height="17" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <path d="M18 6 6 18M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            <form @onsubmit="SaveActivity" @onsubmit:preventDefault>

                <!-- Name -->
                <div class="field-group">
                    <label class="field-label">ACTIVITY NAME</label>
                    <input type="text"
                           class="field-input @(_nameError ? "input-error" : "")"
                           placeholder="e.g. Morning Run"
                           maxlength="200"
                           value="@_form.Name"
                           @oninput="@(e => { _form.Name = e.Value?.ToString() ?? ""; _nameError = false; })" />
                    @if (_nameError)
                    {
                        <p class="field-error">Activity name is required.</p>
                    }
                </div>

                <!-- Description -->
                <div class="field-group">
                    <div class="field-label-row">
                        <label class="field-label">DESCRIPTION</label>
                        <span class="field-hint">Optional · @(_form.Description?.Length ?? 0)/500</span>
                    </div>
                    <textarea class="field-textarea"
                              placeholder="What does this activity involve?"
                              maxlength="500"
                              rows="3"
                              value="@_form.Description"
                              @oninput="@(e => _form.Description = e.Value?.ToString())"></textarea>
                </div>

                <!-- Default Points + Categories — side by side -->
                <div class="form-split-row">

                    <!-- Default Points -->
                    <div class="field-group">
                        <label class="field-label">DEFAULT POINTS</label>
                        <div class="pts-spinner">
                            <button type="button" class="pts-btn" @onclick="DecrementPoints">−</button>
                            <div class="pts-value-wrap @(_form.DefaultPoints > 0 ? "pos" : _form.DefaultPoints < 0 ? "neg" : "")">
                                <span class="pts-num">@(_form.DefaultPoints > 0 ? "+" : "")@_form.DefaultPoints</span>
                                <span class="pts-sub">PER ENTRY</span>
                            </div>
                            <button type="button" class="pts-btn" @onclick="IncrementPoints">+</button>
                        </div>
                    </div>

                    <!-- Categories -->
                    <div class="field-group">
                        <label class="field-label">
                            DIMENSIONS&nbsp;<span class="field-hint-inline">— select at least one</span>
                        </label>
                        <div class="cat-toggle-row">
                            @foreach (var cat in _categories)
                            {
                                var selected = _form.CategoryIds.Contains(cat.Id);
                                <button type="button"
                                        class="cat-toggle-btn @(selected ? "cat-selected" : "")"
                                        style="@(selected ? $"border-color:{cat.ColorHex};background:{cat.ColorHex};color:rgba(0,0,0,0.78)" : $"border-color:{cat.ColorHex}55;color:{cat.ColorHex}CC")"
                                        title="@DimensionDisplayHelper.GetDisplayName(cat)"
                                        aria-label="@DimensionDisplayHelper.GetDisplayName(cat)"
                                        @onclick="@(() => ToggleCategory(cat.Id))">
                                    <span class="cat-toggle-dot" style="background:@(selected ? "rgba(0,0,0,0.22)" : cat.ColorHex)"></span>
                                    <span class="dim-full">@DimensionDisplayHelper.GetDisplayName(cat)</span>
                                    <span class="dim-abbr" aria-hidden="true">@DimensionDisplayHelper.GetMobileLabel(cat)</span>
                                </button>
                            }
                        </div>
                        @if (_showCategoryError)
                        {
                            <p class="field-error">Select at least one dimension.</p>
                        }
                    </div>

                </div>

                <!-- Action buttons -->
                <div class="modal-footer">
                    <div class="modal-footer-left">
                        <button type="submit" class="btn-save" disabled="@_saving">
                            @(_saving ? "Saving…" : (_editingId.HasValue ? "Save changes" : "Create activity"))
                        </button>
                        <button type="button" class="btn-text-cancel" @onclick="CloseForm">CANCEL</button>
                    </div>
                    @if (_editingId.HasValue)
                    {
                        <div class="modal-footer-right">
                            @if (_deleteArmed)
                            {
                                <button type="button" class="act-btn confirm" title="Confirm delete"
                                        @onclick="DeleteFromForm">
                                    <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" fill="currentColor"/>
                                    </svg>
                                </button>
                                <button type="button" class="act-btn cancel-del" title="Cancel delete"
                                        @onclick="@(() => _deleteArmed = false)">
                                    <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/>
                                    </svg>
                                </button>
                            }
                            else
                            {
                                <button type="button" class="act-btn delete" title="Delete activity"
                                        disabled="@_saving"
                                        @onclick="@(() => _deleteArmed = true)">
                                    <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                                        <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="currentColor"/>
                                    </svg>
                                </button>
                            }
                        </div>
                    }
                </div>

            </form>
        </div>
    </div>
}

<!-- ═══ Conflict dialog ═══ -->
@if (_conflictActivity is not null)
{
    <div class="modal-overlay conflict-overlay">
        <div class="modal-card conflict-card">

            <div class="conflict-header">
                <svg class="conflict-icon" viewBox="0 0 24 24" width="20" height="20"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                <h2 class="modal-title">Activity Has History</h2>
            </div>

            <p class="conflict-body">
                <strong class="conflict-name">"@_conflictActivity.Name"</strong> has
                @_conflictLogCount log @(_conflictLogCount == 1 ? "entry" : "entries").
                How would you like to proceed?
            </p>

            <div class="conflict-options">
                <button class="conflict-opt archive-opt" type="button"
                        @onclick="@(() => ResolveConflict("archive"))">
                    <div class="conflict-opt-title">Hide from future logging</div>
                    <div class="conflict-opt-desc">Activity is archived — all history is preserved</div>
                </button>
                <button class="conflict-opt cascade-opt" type="button"
                        @onclick="@(() => ResolveConflict("cascade"))">
                    <div class="conflict-opt-title">Delete activity and all history</div>
                    <div class="conflict-opt-desc">Permanently removes @_conflictLogCount log @(_conflictLogCount == 1 ? "entry" : "entries") — cannot be undone</div>
                </button>
            </div>

            <button class="conflict-cancel-btn" type="button"
                    @onclick="@(() => _conflictActivity = null)">
                Cancel
            </button>

        </div>
    </div>
}

@code {
    /* ── State ─────────────────────────────────────────────── */
    private List<ActivityDto>  _activities  = [];
    private List<CategoryDto>  _categories  = [];
    private string             _search      = string.Empty;
    private bool               _loading     = true;
    private bool               _showForm;
    private bool               _saving;
    private bool               _nameError;
    private bool               _showCategoryError;
    private int?               _editingId;
    private ActivityDto?       _editingActivity;
    private readonly ActivityFormModel _form = new();

    private ActivityDto?       _conflictActivity;
    private int                _conflictLogCount;
    private bool               _deleteArmed;
    private int?               _pendingDeleteActivityId;

    /* ── Computed ──────────────────────────────────────────── */
    private IEnumerable<ActivityDto> FilteredActivities =>
        string.IsNullOrWhiteSpace(_search)
            ? _activities
            : _activities.Where(a => a.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    private static string BadgeBg(ActivityDto a) =>
        a.Categories.Count > 0 ? $"{a.Categories[0].ColorHex}26" : "#4A608026";

    private static string BadgeColor(ActivityDto a) =>
        a.Categories.Count > 0 ? a.Categories[0].ColorHex : "#4A6080";

    /* ── Lifecycle ─────────────────────────────────────────── */
    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var catsTask = CategoryService.GetAllAsync();
        var actsTask = ActivityService.GetAllAsync();
        await Task.WhenAll(catsTask, actsTask);
        _categories = catsTask.Result.ToList();
        _activities = actsTask.Result.ToList();
        _loading = false;
    }

    private async Task ReloadActivities()
    {
        _loading = true;
        StateHasChanged();
        _activities = (await ActivityService.GetAllAsync()).ToList();
        _loading = false;
    }

    /* ── Open / close form ────────────────────────────────── */
    private void OpenCreateForm()
    {
        _editingId          = null;
        _editingActivity    = null;
        _form.Name          = string.Empty;
        _form.Description   = null;
        _form.DefaultPoints = 5;
        _form.CategoryIds.Clear();
        _nameError                  = false;
        _showCategoryError          = false;
        _deleteArmed                = false;
        _pendingDeleteActivityId    = null;
        _showForm                   = true;
    }

    private async Task OpenEditForm(ActivityDto activity)
    {
        _editingId          = activity.Id;
        _editingActivity    = activity;
        _form.Name          = activity.Name;
        _form.Description   = activity.Description;
        _form.DefaultPoints = activity.DefaultPoints;
        _form.CategoryIds   = [.. activity.Categories.Select(c => c.Id)];
        _nameError                  = false;
        _showCategoryError          = false;
        _deleteArmed                = false;
        _pendingDeleteActivityId    = null;
        _showForm                   = true;
        StateHasChanged();
        await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    private void CloseForm()
    {
        _showForm                   = false;
        _nameError                  = false;
        _showCategoryError          = false;
        _deleteArmed                = false;
        _pendingDeleteActivityId    = null;
        _editingActivity            = null;
    }

    /* ── Form field helpers ───────────────────────────────── */
    private void ToggleCategory(int id)
    {
        if (_form.CategoryIds.Contains(id)) _form.CategoryIds.Remove(id);
        else _form.CategoryIds.Add(id);
        _showCategoryError = false;
    }

    private void IncrementPoints() { if (_form.DefaultPoints < 100) _form.DefaultPoints++; }
    private void DecrementPoints() { if (_form.DefaultPoints > -100) _form.DefaultPoints--; }

    /* ── Save ─────────────────────────────────────────────── */
    private async Task SaveActivity()
    {
        _nameError         = string.IsNullOrWhiteSpace(_form.Name);
        _showCategoryError = !_form.CategoryIds.Any();
        if (_nameError || _showCategoryError) return;

        _saving = true;
        var description = string.IsNullOrWhiteSpace(_form.Description) ? null : _form.Description.Trim();

        if (_editingId.HasValue)
        {
            await ActivityService.UpdateAsync(_editingId.Value, new UpdateActivityDto
            {
                Name          = _form.Name.Trim(),
                Description   = description,
                DefaultPoints = _form.DefaultPoints,
                CategoryIds   = _form.CategoryIds
            });
        }
        else
        {
            await ActivityService.CreateAsync(new CreateActivityDto
            {
                Name          = _form.Name.Trim(),
                Description   = description,
                DefaultPoints = _form.DefaultPoints,
                CategoryIds   = _form.CategoryIds
            });
        }

        _saving = false;
        CloseForm();
        Toast.Show("Activity saved.", ToastType.Success);
        await ReloadActivities();
    }

    /* ── Delete ───────────────────────────────────────────── */
    private async Task DeleteActivity(ActivityDto activity)
    {
        var (success, conflict) = await ActivityService.DeleteAsync(activity.Id);

        if (success)
        {
            Toast.Show($"\"{activity.Name}\" deleted.", ToastType.Success);
            await ReloadActivities();
            return;
        }

        if (conflict is not null)
        {
            _conflictActivity = activity;
            _conflictLogCount = conflict.LogCount;
        }
    }

    // Called from the Delete button inside the edit form modal.
    private async Task DeleteFromForm()
    {
        if (_editingActivity is null) return;
        var activity = _editingActivity;
        CloseForm();
        await DeleteActivity(activity);
    }

    private async Task ResolveConflict(string action)
    {
        if (_conflictActivity is null) return;

        var activity = _conflictActivity;
        _conflictActivity = null;

        var (success, _) = await ActivityService.DeleteAsync(activity.Id, action);
        if (success)
        {
            Toast.Show(action == "archive"
                ? $"\"{activity.Name}\" archived."
                : $"\"{activity.Name}\" and all history deleted.",
                ToastType.Success);
            await ReloadActivities();
        }
        else
        {
            Toast.Show("Operation failed. Please try again.", ToastType.Error);
        }
    }

    /* ── Form model ───────────────────────────────────────── */
    private class ActivityFormModel
    {
        public string    Name          { get; set; } = string.Empty;
        public string?   Description   { get; set; }
        public int       DefaultPoints { get; set; } = 5;
        public List<int> CategoryIds   { get; set; } = [];
    }
}
