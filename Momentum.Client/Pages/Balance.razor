@page "/reports/balance"
@attribute [Authorize]
@inject ReportsService ReportsService
@inject CategoryService CategoryService
@inject ActivityLogService LogService

<PageTitle>Balance</PageTitle>

<div class="balance-page">

    @* ═══ Header ═══ *@
    <div class="bal-header">
        <div class="bal-header-left">
            <p class="bal-kicker">REPORTS · BALANCE</p>
            <h1 class="bal-title">How balanced are you?</h1>
            <p class="bal-sub">A look at where your momentum came from this @PeriodWord.</p>
        </div>

        <div class="period-pill">
            <span class="period-label">Period</span>
            <select class="period-select" @onchange="OnPeriodChanged">
                <option value="week"  selected="@(_period == "week")">This Week</option>
                <option value="month" selected="@(_period == "month")">This Month</option>
                <option value="year"  selected="@(_period == "year")">This Year</option>
            </select>
            <svg class="period-chevron" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                <path d="M7 10l5 5 5-5z" fill="currentColor"/>
            </svg>
        </div>
    </div>

    @if (_loading)
    {
        <div class="bal-state">
            <p class="loading-text">Loading…</p>
        </div>
    }
    else if (_balance.Count == 0)
    {
        <div class="bal-state">
            <p class="empty-text">No activity logged for this @PeriodWord.</p>
        </div>
    }
    else
    {
        // Pre-compute all locals before entering markup — Razor scoping requirement
        var dominant = _balance[0];
        var domPct   = GrandTotal > 0 ? (int)Math.Round(dominant.Total * 100.0 / GrandTotal) : 0;
        var weakest  = _balance.Count > 1 ? _balance[^1] : null;
        var secondWk = _balance.Count > 2 ? _balance[^2] : null;
        var days     = DayScores;
        var bestDays = days.Take(2).ToList();
        var worstDay = days.Count > 2 ? days[^1] : null;

        @* ═══ Main card: donut + category list ═══ *@
        <div class="main-card">

            <div class="donut-wrap">
                <svg class="donut-svg" viewBox="0 0 160 160"
                     xmlns="http://www.w3.org/2000/svg"
                     role="img" aria-label="Dimension balance ring chart">
                    <circle cx="80" cy="80" r="56" fill="none"
                            stroke="var(--surface-3)" stroke-width="18"/>
                    @(new MarkupString(BuildDonutArcs()))
                    <text x="80" y="71" text-anchor="middle"
                          style="font-size:9px;font-family:'DM Sans',sans-serif;fill:var(--text-muted);letter-spacing:0.04em">Total</text>
                    <text x="80" y="93" text-anchor="middle"
                          style="font-size:27px;font-weight:700;font-family:'Space Grotesk',sans-serif;fill:var(--text)">@GrandTotal</text>
                    <text x="80" y="108" text-anchor="middle"
                          style="font-size:8px;font-weight:600;letter-spacing:0.12em;font-family:'DM Sans',sans-serif;fill:var(--text-muted)">PTS</text>
                </svg>
            </div>

            <div class="cat-list">
                @foreach (var cat in _balance)
                {
                    var pct     = GrandTotal > 0 ? (int)Math.Round(cat.Total * 100.0 / GrandTotal) : 0;
                    var fillPct = GrandTotal > 0 ? Math.Min(100.0, cat.Total * 100.0 / GrandTotal) : 0.0;
                    var fillStr = fillPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                    <div class="cat-row">
                        <span class="cat-dot" style="background:@cat.ColorHex"></span>
                        <div class="cat-info">
                            <span class="cat-name">@DimensionDisplayHelper.GetDisplayName(cat)</span>
                            <span class="cat-pts-sub">@cat.Total pts</span>
                        </div>
                        <span class="cat-pct">@pct%</span>
                        <div class="cat-bar-track">
                            <div class="cat-bar-fill" style="width:@fillStr%;background:@cat.ColorHex"></div>
                        </div>
                    </div>
                }
            </div>

        </div>

        @* ═══ Insight callout ═══ *@
        <div class="insight-card">
            <div class="insight-icon">
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                    <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5"
                          stroke-linecap="round" fill="none"/>
                </svg>
            </div>
            <div class="insight-body">
                <p class="insight-headline">Your @DimensionDisplayHelper.GetDisplayName(dominant).ToLower() dimension is dominating (@domPct%).</p>
                <p class="insight-sub">
                    @if (secondWk is not null && weakest is not null && weakest.CategoryId != dominant.CategoryId)
                    {
                        @($"Adding two {DimensionDisplayHelper.GetDisplayName(secondWk)} or {DimensionDisplayHelper.GetDisplayName(weakest)} entries this {PeriodWord} would bring you closer to an even balance.")
                    }
                    else if (weakest is not null && weakest.CategoryId != dominant.CategoryId)
                    {
                        @($"Adding more {DimensionDisplayHelper.GetDisplayName(weakest)} entries this {PeriodWord} would bring you closer to an even balance.")
                    }
                </p>
            </div>
        </div>

        @* ═══ Best & worst days ═══ *@
        <div class="bwd-card">
            <div class="bwd-head">
                <span class="bwd-title">Best &amp; worst days</span>
                <span class="bwd-period">@PeriodCapitalized</span>
            </div>
            <div class="bwd-list">
                @if (days.Count == 0)
                {
                    <p class="bwd-empty">No entries logged this @PeriodWord.</p>
                }
                @foreach (var day in bestDays)
                {
                    <div class="bwd-row">
                        <div class="bwd-badge good">
                            <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                                <path d="M7 14l5-5 5 5z" fill="currentColor"/>
                            </svg>
                        </div>
                        <div class="bwd-info">
                            <span class="bwd-day">@day.DayName <span class="bwd-date-inline">· @day.DateLabel</span></span>
                            <span class="bwd-act">@day.TopActivity</span>
                        </div>
                        <span class="bwd-pts good">+@day.Total</span>
                    </div>
                }
                @if (worstDay is not null)
                {
                    <div class="bwd-row">
                        <div class="bwd-badge bad">
                            <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                                <path d="M7 10l5 5 5-5z" fill="currentColor"/>
                            </svg>
                        </div>
                        <div class="bwd-info">
                            <span class="bwd-day">@worstDay.DayName <span class="bwd-date-inline">· @worstDay.DateLabel</span></span>
                            <span class="bwd-act">@worstDay.TopActivity</span>
                        </div>
                        <span class="bwd-pts @(worstDay.Total >= 0 ? "good" : "bad")">
                            @(worstDay.Total > 0 ? "+" : "")@worstDay.Total
                        </span>
                    </div>
                }
            </div>
        </div>
    }

</div>

@code {
    private string                  _period     = "week";
    private List<CategoryTotalDto>  _balance    = [];
    private List<CategoryDto>       _categories = [];
    private List<ActivityLogDto>    _periodLogs = [];
    private bool _loading = true;

    // ── Computed ──────────────────────────────────────────────
    private string PeriodWord        => _period switch { "month" => "month", "year" => "year", _ => "week" };
    private string PeriodCapitalized => _period switch { "month" => "This month", "year" => "This year", _ => "This week" };
    private int    GrandTotal        => _balance.Sum(b => b.Total);

    private record DayInfo(DateOnly Date, string DayName, string DateLabel, int Total, string TopActivity);

    private List<DayInfo> DayScores => _periodLogs
        .GroupBy(l => DateOnly.FromDateTime(l.LoggedAt.ToLocalTime()))
        .Select(g =>
        {
            var topLog = g.OrderByDescending(l => l.PointsRecorded).First();
            return new DayInfo(
                g.Key,
                g.Key.ToDateTime(TimeOnly.MinValue).ToString("dddd"),
                g.Key.ToString("MM/dd/yyyy"),
                g.Sum(l => l.PointsRecorded),
                topLog.ActivityName ?? "");
        })
        .OrderByDescending(d => d.Total)
        .ToList();

    // ── Lifecycle ─────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _categories = (await CategoryService.GetAllAsync())
            .OrderBy(c => c.Id)
            .ToList();
        await LoadData();
    }

    private async Task OnPeriodChanged(ChangeEventArgs e)
    {
        _period = e.Value?.ToString() ?? "week";
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();

        var tBalance = ReportsService.GetBalanceAsync(_period);
        var tLogs    = LogService.GetByDateRangeAsync(GetPeriodFrom(), DateTime.UtcNow);

        await Task.WhenAll(tBalance, tLogs);

        _balance    = tBalance.Result.OrderByDescending(b => b.Total).ToList();
        _periodLogs = tLogs.Result;

        _loading = false;
    }

    private DateTime GetPeriodFrom()
    {
        var localToday = DateTime.Today; // browser local midnight
        return _period switch
        {
            "month" => localToday.AddDays(1 - localToday.Day).ToUniversalTime(),
            "year"  => localToday.AddDays(1 - localToday.DayOfYear).ToUniversalTime(),
            _       => localToday.AddDays(-(int)localToday.DayOfWeek).ToUniversalTime()
        };
    }

    // ── Donut SVG ─────────────────────────────────────────────
    private string BuildDonutArcs()
    {
        const double cx = 80, cy = 80, r = 56, strokeW = 18, gap = 3.0;
        var circ  = 2.0 * Math.PI * r;   // ≈ 351.86
        var total = (double)GrandTotal;
        if (total <= 0) return "";

        var ic = System.Globalization.CultureInfo.InvariantCulture;
        var sb = new System.Text.StringBuilder();
        double cumPts = 0;

        foreach (var cat in _balance)
        {
            if (cat.Total <= 0) continue;
            double segLen     = Math.Max(0, cat.Total * circ / total - gap);
            double startAngle = cumPts / total * 360.0 - 90.0;
            sb.Append($"<circle cx=\"{cx}\" cy=\"{cy}\" r=\"{r}\" fill=\"none\"" +
                      $" stroke=\"{cat.ColorHex}\" stroke-width=\"{strokeW}\"" +
                      $" stroke-dasharray=\"{segLen.ToString("F2", ic)} {circ.ToString("F2", ic)}\"" +
                      $" transform=\"rotate({startAngle.ToString("F2", ic)} {cx} {cy})\"/>");
            cumPts += cat.Total;
        }

        return sb.ToString();
    }
}
